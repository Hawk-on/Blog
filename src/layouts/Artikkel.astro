---
import Grunnoppsett from './Grunnoppsett.astro';
import { formaterDato } from '../utils/dato';
import GiscusKommentarar from '../components/GiscusKommentarar/GiscusKommentarar';
import ArtikkelMeta from '../components/ArtikkelMeta/ArtikkelMeta';
import Innhaldstabell from '../components/Innhaldstabell/Innhaldstabell';
import LeseProgresjon from '../components/LeseProgresjon/LeseProgresjon';
import { getCollection } from 'astro:content';

interface Props {
  frontmatter: {
    slug?: string;
    tittel: string;
    dato: string | Date;
    ingress?: string;
    tags?: string[];
    lesetid?: number;
    bilete?: string;
  }
}

const { frontmatter } = Astro.props;
const { tittel, dato, ingress, tags = [], lesetid, bilete } = frontmatter;
const base = import.meta.env.BASE_URL;
const aktuellSlug = Astro.url.pathname.split('/').pop() || '';

const datoFormatert = formaterDato(dato, 'lang');

// Finn relaterte artiklar basert på tags
const alleInnlegg = await getCollection('blog', ({ data }) => {
  return (import.meta.env.DEV || !data.utkast) && data.tittel !== tittel;
});

const relaterteInnlegg = alleInnlegg
  .map(innlegg => {
    const fellesTags = innlegg.data.tags.filter(t => tags.includes(t)).length;
    return { ...innlegg, fellesTags };
  })
  .filter(innlegg => innlegg.fellesTags > 0)
  .sort((a, b) => b.fellesTags - a.fellesTags || b.data.dato.valueOf() - a.data.dato.valueOf())
  .slice(0, 3);
---

<Grunnoppsett tittel={tittel} beskriving={ingress} erArtikkel={true} bilete={bilete}>
  <div class="container">
    <header class="artikkel-header">
      <ArtikkelMeta 
        client:load 
        datoFormatert={datoFormatert} 
        lesetid={lesetid} 
        tags={tags} 
        base={base} 
      />
      <h1 class="artikkel-header__tittel">{tittel}</h1>
      {ingress && <p class="artikkel-header__ingress">{ingress}</p>}
    </header>

    <Innhaldstabell client:idle />

    <article class="artikkel-kropp" id="artikkel-kropp">
      <slot />
    </article>

    {relaterteInnlegg.length > 0 && (
      <section class="relaterte-artiklar">
        <h2 class="seksjon-tittel">Les meir om emnet</h2>
        <ul className="artikkel-liste">
          {relaterteInnlegg.map(innlegg => (
            <li key={innlegg.id} className="artikkel-kort artikkel-kort--sm">
              <div className="artikkel-kort__dato">{formaterDato(innlegg.data.dato)}</div>
              <div>
                <h3 className="artikkel-kort__tittel">
                  <a href={`${base}/${innlegg.id}`}>{innlegg.data.tittel}</a>
                </h3>
              </div>
            </li>
          ))}
        </ul>
      </section>
    )}

    <GiscusKommentarar client:only="react" />

    <LeseProgresjon client:idle manueltLesetid={lesetid} />

    <nav class="artikkel-tilbake-nav">
      <a href={base} class="artikkel-tilbake-lenke" data-umami-event="artikkel-tilbake">
        ← Tilbake til alle innlegg
      </a>
    </nav>
  </div>
</Grunnoppsett>

<script>
  // Fotnote Preview Logikk
  function initFotnotePreview() {
    const referansar = document.querySelectorAll('a[href^="#ref-"]');
    
    referansar.forEach(ref => {
      ref.addEventListener('mouseenter', (e) => {
        const targetId = (e.currentTarget as HTMLAnchorElement).getAttribute('href')?.substring(1);
        if (!targetId) return;

        const kjeldeElement = document.getElementById(targetId);
        if (!kjeldeElement) return;

        // Lag preview-boks
        const preview = document.createElement('div');
        preview.className = 'fotnote-preview';
        preview.innerHTML = kjeldeElement.innerHTML;
        
        // Posisjonering
        const rect = (e.currentTarget as HTMLElement).getBoundingClientRect();
        preview.style.top = `${rect.top + window.scrollY - 10}px`;
        preview.style.left = `${rect.left + window.scrollX}px`;
        
        document.body.appendChild(preview);

        // Fjern når musa forlet
        const removePreview = () => {
          preview.remove();
          ref.removeEventListener('mouseleave', removePreview);
        };
        ref.addEventListener('mouseleave', removePreview);
      });
    });
  }

  // Køyr ved oppstart og etter Astro-navigering
  initFotnotePreview();
  document.addEventListener('astro:after-swap', initFotnotePreview);
</script>

<style is:global>
  .fotnote-preview {
    position: absolute;
    transform: translateY(-100%);
    background: var(--kvit);
    border: 1px solid var(--lys-grå);
    padding: 0.75rem 1rem;
    box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    max-width: 350px;
    font-size: 0.85rem;
    line-height: 1.5;
    z-index: 1000;
    pointer-events: none;
    font-family: var(--skrift-brød);
    border-top: 2px solid var(--raud);
  }

  html[data-theme="dark"] .fotnote-preview {
    background: var(--kvit);
    box-shadow: 0 10px 25px rgba(0,0,0,0.4);
  }
</style>
