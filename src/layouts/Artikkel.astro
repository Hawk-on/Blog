---
import Grunnoppsett from './Grunnoppsett.astro';

interface Props {
  tittel: string;
  dato: string;
  ingress?: string;
  tags?: string[];
  lesetid?: number;
}

const { tittel, dato, ingress, tags = [], lesetid } = Astro.props;
const base = import.meta.env.BASE_URL;

const datoFormatert = new Date(dato).toLocaleDateString('nn-NO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<Grunnoppsett tittel={tittel} beskriving={ingress} erArtikkel={true}>
  <div class="container">
    <header class="artikkel-header">
      <div class="artikkel-header__meta">
        <span>{datoFormatert}</span>
        {lesetid && <span>~{lesetid} min lesing</span>}
        {tags.map(tag => <a href={`${base}/blogg/tag/${tag}`} class="tag" data-umami-event="tagg-klikk" data-umami-event-tag={tag}>{tag}</a>)}
      </div>
      <h1 class="artikkel-header__tittel">{tittel}</h1>
      {ingress && <p class="artikkel-header__ingress">{ingress}</p>}
    </header>

    <article class="artikkel-kropp">
      <slot />
    </article>

    <script>
      const milestones = [25, 50, 75, 100];
      const reached = new Set();
      window.addEventListener('scroll', () => {
        const el = document.documentElement;
        const pct = Math.round((el.scrollTop / (el.scrollHeight - el.clientHeight)) * 100);
        for (const m of milestones) {
          if (pct >= m && !reached.has(m)) {
            reached.add(m);
            if (typeof umami !== 'undefined') {
              umami.track('les-djupn', { prosent: m, tittel: document.title });
            }
          }
        }
      }, { passive: true });
    </script>

    <nav style="border-top: 1px solid var(--lys-grå); padding-top: 2rem; margin-top: 2rem;">
      <a href={`${base}/blogg`} style="font-family: var(--skrift-kode); font-size: 0.8rem; letter-spacing: 0.05em; text-decoration: none; color: var(--grå);" data-umami-event="artikkel-tilbake">
        ← Tilbake til alle innlegg
      </a>
    </nav>
  </div>
</Grunnoppsett>
