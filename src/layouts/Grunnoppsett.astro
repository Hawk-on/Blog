---
import '../styles/global.css';
import Header from '../components/Header/Header';
import Footer from '../components/Footer/Footer';
import { ClientRouter } from 'astro:transitions';

interface Props {
  tittel: string;
  beskriving?: string;
  erArtikkel?: boolean;
  bilete?: string;
}

const { 
  tittel, 
  beskriving = 'Analysar av politikk, økonomi og teknologi.', 
  erArtikkel = false,
  bilete = '/favicon-header.png'
} = Astro.props;

const base = import.meta.env.BASE_URL;
const aktuellSti = Astro.url.pathname;
const siteUrl = Astro.site ? Astro.site.toString() : 'https://hawk-on.github.io/Blog';
const kanoniskUrl = new URL(aktuellSti, siteUrl).toString();
const fullTittel = `${tittel} — hawk-on`;
const bileteUrl = new URL(bilete.startsWith('http') ? bilete : `${base}${bilete}`, siteUrl).toString();

const jsonLd = erArtikkel ? {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": tittel,
  "description": beskriving,
  "image": bileteUrl,
  "author": {
    "@type": "Person",
    "name": "Håkon Hole Lønning",
    "url": "https://github.com/hawk-on"
  },
  "url": kanoniskUrl,
  "inLanguage": "nn-NO"
} : {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "hawk-on",
  "alternateName": "Håkon Hole Lønning Blogg",
  "url": siteUrl
};
---

<!DOCTYPE html>
<html lang="nn">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={beskriving} />
  <title>{fullTittel}</title>
  <link rel="canonical" href={kanoniskUrl} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <meta property="og:title" content={fullTittel} />
  <meta property="og:description" content={beskriving} />
  <meta property="og:url" content={kanoniskUrl} />
  <meta property="og:type" content={erArtikkel ? 'article' : 'website'} />
  <meta property="og:image" content={bileteUrl} />
  <meta property="og:locale" content="nn_NO" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTittel} />
  <meta name="twitter:description" content={beskriving} />
  <meta name="twitter:image" content={bileteUrl} />
  <link rel="icon" type="image/x-icon" href={`${base}/favicon.ico`} />
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  <link rel="alternate" type="application/rss+xml" title="RSS" href={`${base}/rss.xml`} />
  <script defer src="https://cloud.umami.is/script.js" data-website-id="fd43352d-8e75-4352-8f82-92eb8a269859"></script>
  <ClientRouter />
  <script is:inline>
    function setTema() {
      try {
        var t = localStorage.getItem('theme');
        if (t) document.documentElement.setAttribute('data-theme', t);
      } catch (e) {}
    }
    setTema();
    document.addEventListener('astro:after-swap', setTema);
  </script>
</head>
<body>

  <a href="#hovudinnhald" class="hopp-til-innhald">Hopp til innhald</a>

  <Header client:load base={base} aktuellSti={aktuellSti} />

  <main id="hovudinnhald">
    <slot />
  </main>

  <Footer />

</body>
</html>
