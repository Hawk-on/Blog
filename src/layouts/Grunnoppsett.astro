---
import '../styles/global.css';
import Header from '../components/Header/Header';
import Footer from '../components/Footer/Footer';

interface Props {
  tittel: string;
  beskriving?: string;
  erArtikkel?: boolean;
}

const { tittel, beskriving = 'Analysar av politikk, økonomi og teknologi.', erArtikkel = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const aktuellSti = Astro.url.pathname;
const kanoniskUrl = new URL(aktuellSti, Astro.site).toString();
const fullTittel = `${tittel} — hawk-on`;
---

<!DOCTYPE html>
<html lang="nn">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={beskriving} />
  <title>{fullTittel}</title>
  <link rel="canonical" href={kanoniskUrl} />
  <meta property="og:title" content={fullTittel} />
  <meta property="og:description" content={beskriving} />
  <meta property="og:url" content={kanoniskUrl} />
  <meta property="og:type" content={erArtikkel ? 'article' : 'website'} />
  <meta property="og:locale" content="nn_NO" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={fullTittel} />
  <meta name="twitter:description" content={beskriving} />
  <link rel="icon" type="image/x-icon" href={`${base}/favicon.ico`} />
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  <link rel="alternate" type="application/rss+xml" title="RSS" href={`${base}/rss.xml`} />
  <script defer src="https://cloud.umami.is/script.js" data-website-id="fd43352d-8e75-4352-8f82-92eb8a269859"></script>
  <script is:inline>
    (function() {
      try {
        var t = localStorage.getItem('theme');
        if (t) document.documentElement.setAttribute('data-theme', t);
      } catch (e) {}
    })();
  </script>
</head>
<body>

  <a href="#hovudinnhald" class="hopp-til-innhald">Hopp til innhald</a>

  <Header client:load base={base} aktuellSti={aktuellSti} />

  <main id="hovudinnhald">
    <slot />
  </main>

  <Footer />

</body>
</html>
