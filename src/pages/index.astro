---
import { getCollection } from 'astro:content';
import Grunnoppsett from '../layouts/Grunnoppsett.astro';
import { formaterDato } from '../utils/dato';
import { reknaUtLesetid, genererUtdrag } from '../utils/tekst';
import ArtikkelListe from '../components/ArtikkelListe/ArtikkelListe';

const base = import.meta.env.BASE_URL;
const innlegg = await getCollection('blog', ({ data }) => {
  return import.meta.env.DEV || !data.utkast;
});

const sortertInnleggData = innlegg
  .sort((a, b) => b.data.dato.valueOf() - a.data.dato.valueOf())
  .map(i => ({
    tittel: i.data.tittel,
    dato: i.data.dato,
    ingress: i.data.ingress || genererUtdrag(i.body),
    lesetid: i.data.lesetid || reknaUtLesetid(i.body),
    tags: i.data.tags ?? [],
    slug: i.slug,
    datoFormatert: formaterDato(i.data.dato)
  }));

const tagFrekvens = new Map<string, number>();
sortertInnleggData.forEach(i =>
  i.tags.forEach((t: string) =>
    tagFrekvens.set(t, (tagFrekvens.get(t) ?? 0) + 1)
  )
);
const sorterteTags = [...tagFrekvens.entries()]
  .sort((a, b) => b[1] - a[1])
  .map(([t]) => t);
---

<Grunnoppsett tittel="hawk-on">
  <div class="container">

    <section class="forsida-hero">
      <div class="forsida-hero__kicker">Analysar · Geopolitikk · Teknologi</div>
      <h1 class="forsida-hero__tittel">Tankar om makt, system og kva som eigentleg skjer</h1>
      <p class="forsida-hero__beskriving">
        Seniorutviklar og samfunnsengasjert frå Osterøy.
        Eg skriv om politisk økonomi, geopolitikk og teknologi.
      </p>
    </section>

    <ArtikkelListe 
      client:load 
      alleInnlegg={sortertInnleggData} 
      sorterteTags={sorterteTags} 
      base={base} 
    />

  </div>
</Grunnoppsett>
