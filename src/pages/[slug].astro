---
import { getCollection, render } from 'astro:content';
import Artikkel from '../layouts/Artikkel.astro';
import { reknaUtLesetid } from '../utils/tekst';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog', ({ data }) => {
    return import.meta.env.DEV || !data.utkast;
  });
  return blogEntries.map(entry => ({
    params: { slug: entry.id }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const frontmatter = {
  ...entry.data,
  lesetid: entry.data.lesetid || reknaUtLesetid(entry.body || '')
};
---

<Artikkel frontmatter={frontmatter}>
  <Content />
</Artikkel>
