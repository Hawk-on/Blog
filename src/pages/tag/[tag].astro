---
import Grunnoppsett from '../../layouts/Grunnoppsett.astro';
import { formaterDato } from '../../utils/dato';

export async function getStaticPaths() {
  const innlegg = await Astro.glob('../*.md');
  const alleTaggar = innlegg.flatMap(i => i.frontmatter.tags ?? []);
  const unikeTaggar = [...new Set(alleTaggar)];

  return unikeTaggar.map(tag => ({
    params: { tag },
    props: {
      innlegg: innlegg.filter(i => (i.frontmatter.tags ?? []).includes(tag)),
      tag,
    },
  }));
}

const { innlegg, tag } = Astro.props;
const base = import.meta.env.BASE_URL;
const sortertInnlegg = innlegg.sort(
  (a, b) => new Date(b.frontmatter.dato).valueOf() - new Date(a.frontmatter.dato).valueOf()
);
---

<Grunnoppsett tittel={`#${tag}`} beskriving={`Alle innlegg merka med ${tag}`}>
  <div class="container">
    <div class="tag-header">
      <p class="seksjon-tittel"><a href={base} class="tag-header__tilbake">Alle innlegg</a></p>
      <h1 class="tag-header__tittel">#{tag}</h1>
      <p class="tag-header__tal">
        {sortertInnlegg.length} {sortertInnlegg.length === 1 ? 'innlegg' : 'innlegg'}
      </p>
    </div>

    <ul class="artikkel-liste">
      {sortertInnlegg.map(innlegg => {
        const { tittel, dato, ingress, tags = [] } = innlegg.frontmatter;
        const datoFormatert = formaterDato(dato);
        const slug = innlegg.file.split('/').pop()?.replace('.md', '');
        return (
          <li class="artikkel-kort">
            <div class="artikkel-kort__dato">{datoFormatert}</div>
            <div>
              <h2 class="artikkel-kort__tittel">
                <a href={`${base}/${slug}`}>{tittel}</a>
              </h2>
              {ingress && <p class="artikkel-kort__ingress">{ingress}</p>}
              {tags.length > 0 && (
                <div class="artikkel-kort__tags">
                  {tags.map((t: string) => (
                    <a href={`${base}/tag/${t}`} class="tag" data-umami-event="tagg-klikk" data-umami-event-tag={t}>{t}</a>
                  ))}
                </div>
              )}
            </div>
          </li>
        );
      })}
    </ul>
  </div>
</Grunnoppsett>
